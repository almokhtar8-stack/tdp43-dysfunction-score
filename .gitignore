# Data files (too large for GitHub)
data/raw/*
data/processed/*
data/references/*

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/combined/.gitkeep
!data/results/.gitkeep

# R files
.Rhistory
.RData
.Rproj.user
*.Rproj

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
*.pkl
*.h5

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Backup files
*.save
*~
*.backup

# Large Salmon quantification files
results/salmon/*/quant.sf
results/salmon/*/aux_info/
results/salmon/*/libParams/
results/salmon/*/logs/
results/salmon/*/cmd_info.json
results/salmon/*/lib_format_counts.json

# Large QC files
results/qc/fastqc/*.html
results/qc/fastqc/*.zip
results/qc/multiqc/multiqc_data/

# But KEEP small summary files!
!results/qc/salmon/*.csv
!results/qc/salmon/*.png
!results/qc/multiqc/multiqc_report.html

# Temporary files
repo_structure.txt
TEAM_GITHUB_GUIDE.md.save
